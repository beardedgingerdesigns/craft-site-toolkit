<picture>
{% if images.length == 1 %}
<source srcset="{{ image[0].url(thumb) }}" type="image/{{ image[0].extension }}">
<img alt="{{ title.title }}"  src="{{ image[0].url(thumb) }}">
</picture>
{% else %}
{% for image in images %}
{% if image.extension == 'jpg' %}
<source srcset="{{ image.url(thumb) }}" type="image/{{ image.extension }}">
<img alt="{{ title.title }}"  src="{{ image.url(thumb) }}">
{% else %}
<source srcset="{{ image.url() }}" type="image/{{ image.extension }}">
{% endif %}
{% endfor %}
</picture>