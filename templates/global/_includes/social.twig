
{% set socialList = seomatic.site.sameAsLinks %}

{% for social in socialList %}
{% if social["url"] | length %}<li class="{{ class }} social-links {{ social["handle"] }}"><a title="{{ social["handle"] }}" href="{{ social["url"] }}" target="_blank"><i class="fa-brands fa-{{ social["handle"] }}"></i></a></li>{% endif %}
{% endfor %}

