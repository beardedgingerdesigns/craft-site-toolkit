{% set fullCrop = {
    quality:30
} %}

{% set crop = {
   width:600,
   height:600
}
%}


{% set width = child.columnWidth %}

{% if width == 'evenSpace' %}
    {% set width = "" %}
{% else %}
    {% set width = "-"~width %}
{% endif %}

{% set items = child.images.all() %}
        <div class="row g-2">

               {% for item in items %}
                <div class="col-6 col-lg{{ width }} gallery-col">
                  <a data-fancybox="gallery" href="{{ item.url(fullCrop) }}"><img src="{{ item.url(crop) }}" style="width:auto" alt=""></a>
                </div>
                {% endfor %}

        
        </div>
